{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "pyddlvector: Example (wirepod)",
      "type": "python",
      "request": "launch",
      "python": "${workspaceFolder}/.venv/bin/python",
      "program": "${workspaceFolder}/examples/connect_vector_t3x9.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "subProcess": true,
      "justMyCode": true,
      "args": [
        "--mode",
        "wirepod"
      ],
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src"
      }
    },
    {
      "name": "pyddlvector: Example (official)",
      "type": "python",
      "request": "launch",
      "python": "${workspaceFolder}/.venv/bin/python",
      "program": "${workspaceFolder}/examples/connect_vector_t3x9.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "subProcess": true,
      "justMyCode": true,
      "args": [
        "--mode",
        "official"
      ],
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src",
        "VECTOR_EMAIL": "",
        "VECTOR_PASSWORD": ""
      }
    }
  ]
}
